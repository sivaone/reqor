{
  "name": "@reqor/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "reqor": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/add-shebang.mjs",
