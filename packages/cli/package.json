    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@reqor/server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
